# LLM API configuration (supports any LLM API compatible with OpenAI SDK format) / Configurazione API LLM (supporta qualsiasi API LLM compatibile con formato OpenAI SDK)
# Recommended: Alibaba Bailian qwen-plus model: https://bailian.console.aliyun.com/ / Consigliato: modello Alibaba Bailian qwen-plus: https://bailian.console.aliyun.com/
# High token consumption: start with simulations below 40 rounds / Consumo elevato di token: inizia con simulazioni sotto i 40 round
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP graph memory configuration / Configurazione memoria grafo ZEP =====
# Monthly free tier is enough for basic usage: https://app.getzep.com/ / Il piano gratuito mensile e sufficiente per uso base: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM configuration (optional) / Configurazione LLM accelerata (opzionale) =====
# If you do not use acceleration, do not include the keys below in the env file / Se non usi l'accelerazione, non includere le chiavi sotto nel file env
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here